{
  "name": "ash-memory-search",
  "version": "1.0.0",
  "description": "AI-powered semantic search engine for memory files",
  "main": "index.js",
  "exports": {
    ".": {
      "require": "./index.js",
      "import": "./index.mjs"
    },
    "./search": "./src/search.js",
    "./server": "./src/server.js",
    "./storage": "./src/storage.js"
  },
  "bin": {
    "ash-memory-search": "./bin/ash-memory-search",
    "memory-search": "./bin/memory-search",
    "memory-search-server": "./bin/memory-search-server",
    "memory-search-setup": "./bin/memory-search-setup"
  },
  "scripts": {
    "index": "node src/build-index.js",
    "search": "node bin/memory-search",
    "server": "node bin/memory-search-server",
    "setup": "node bin/memory-search-setup",
    "test": "node tests/unit-tests.js",
    "benchmark": "node tests/benchmark.js",
    "test:all": "node tests/run-all.js"
  },
  "keywords": ["search", "memory", "semantic", "embeddings", "openclaw", "sqlite", "ai"],
  "author": "ashcommand",
  "license": "MIT",
  "dependencies": {
    "@xenova/transformers": "^2.15.0",
    "better-sqlite3": "^9.2.2",
    "dotenv": "^16.3.1",
    "chalk": "^5.3.0",
    "inquirer": "^9.2.12"
  },
  "devDependencies": {
    "tap": "^18.6.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ashcommand/ash-memory-search.git"
  },
  "bugs": {
    "url": "https://github.com/ashcommand/ash-memory-search/issues"
  },
  "homepage": "https://github.com/ashcommand/ash-memory-search#readme"
}
